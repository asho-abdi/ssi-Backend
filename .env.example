# Railway / production — set all of these in the platform dashboard
NODE_ENV=production
# On Railway do NOT set PORT manually — the platform injects it.
# LISTEN_HOST=0.0.0.0   # optional: force IPv4 bind; omit on Railway for dual-stack default
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/elearning?retryWrites=true&w=majority
JWT_SECRET=use_a_long_random_string_at_least_32_characters
CLIENT_URL=https://your-frontend.vercel.app

# ImageKit — required for uploads (images + course files). Dashboard → Developer options.
IMAGEKIT_PUBLIC_KEY=public_xxx
IMAGEKIT_PRIVATE_KEY=private_xxx
# e.g. https://ik.imagekit.io/your_imagekit_id (no trailing slash)
IMAGEKIT_URL_ENDPOINT=https://ik.imagekit.io/your_imagekit_id

# Optional alias (if you still use MONGODB_URI elsewhere)
# MONGODB_URI=

JWT_EXPIRES_IN=7d

# Local development (copy to .env)
# NODE_ENV=development
# PORT=5000
# MONGO_URI=mongodb://127.0.0.1:27017/elearning
# CLIENT_URL=http://localhost:5173
# JWT_SECRET=dev_only_secret

# --- WhatsApp Cloud API + AI (optional) ---
# Webhook URL: https://YOUR_HOST/webhook
# VERIFY_TOKEN = random string; same value entered in Meta webhook config
# WHATSAPP_APP_SECRET = Meta App Secret (for X-Hub-Signature-256); optional in dev
# WHATSAPP_TOKEN = Temporary or permanent access token with whatsapp_business_messaging
# PHONE_NUMBER_ID = WhatsApp > API setup > Phone number ID
# WHATSAPP_GRAPH_VERSION=v18.0
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_SYSTEM_PROMPT=You are a helpful assistant...
