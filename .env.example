# === Production (Render + Atlas + Vercel) ===
NODE_ENV=production
PORT=5000
# Atlas (use either name; password must be URL-encoded, e.g. @ → %40)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/elearning?retryWrites=true&w=majority
# MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/elearning?retryWrites=true&w=majority

JWT_SECRET=use_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# Comma-separated allowed browser origins (no trailing slash). First = primary (email links).
# Example: https://your-app.vercel.app
# Multiple: https://app.com,https://www.app.com
CLIENT_ORIGIN=https://your-frontend.vercel.app
# CLIENT_URL=https://your-frontend.vercel.app

# Optional (see .env.example Stripe block if you enable payments)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# === Local development ===
# NODE_ENV=development
# PORT=5000
# CLIENT_ORIGIN=http://localhost:5173
# MONGODB_URI=mongodb://127.0.0.1:27017/elearning
