# Railway / production — set all of these in the platform dashboard
NODE_ENV=production
# On Railway do NOT set PORT manually — the platform injects it.
# LISTEN_HOST=0.0.0.0   # optional: force IPv4 bind; omit on Railway for dual-stack default
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/elearning?retryWrites=true&w=majority
JWT_SECRET=use_a_long_random_string_at_least_32_characters
CLIENT_URL=https://your-frontend.vercel.app
# Optional: YouTube Data API key — resolves real video length (mm:ss) for YouTube lesson URLs on course/watch pages.
# YOUTUBE_API_KEY=
# Optional: public origin where /uploads/* is served (no trailing slash). Set on Railway to your
# service URL so stored file URLs stay correct and match TLS (e.g. https://xxx.up.railway.app).
# If unset, the server builds URLs from the incoming request host (can be wrong behind some proxies).
# PUBLIC_MEDIA_ORIGIN=https://your-backend.up.railway.app

# Optional alias (if you still use MONGODB_URI elsewhere)
# MONGODB_URI=

JWT_EXPIRES_IN=7d

# Local development (copy to .env)
# NODE_ENV=development
# PORT=5001
# MONGO_URI=mongodb://127.0.0.1:27017/elearning
# CLIENT_URL=http://localhost:5173

# JWT_SECRET=dev_only_secret

# SMTP (password reset emails)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-smtp-user
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@example.com

# WhatsApp OTP (password reset via WhatsApp)
# WHATSAPP_TOKEN=your-meta-whatsapp-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_GRAPH_VERSION=v21.0
# WHATSAPP_DEFAULT_COUNTRY_CODE=252

# OTP settings (password reset)
# OTP_TTL_MS=600000
# OTP_MAX_PER_HOUR=5
# RESET_SESSION_TTL_MS=900000
