{
  "name": "elearning-backend",
  "version": "1.0.0",
  "description": "E-learning platform API",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/seed.js",
    "start:platform": "node src/platform/server.js",
    "dev:platform": "node --watch src/platform/server.js",
    "migrate:analyze": "node migration/src/analyze.js",
    "migrate:run": "node migration/src/run.js",
    "migrate:rollback": "node migration/src/rollback.js",
    "migrate:rollback:list": "node migration/src/rollback.js --list"
  },
  "dependencies": {
    "axios": "^1.7.9",
    "bcryptjs": "^2.4.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.5.2",
    "express-validator": "^7.2.0",
    "helmet": "^8.2.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.7.0",
    "multer": "^2.1.1",
    "mysql2": "^3.11.0",
    "nodemailer": "^9.0.3",
    "pdfkit": "^0.15.0",
    "qrcode": "^1.5.4"
  }
}
